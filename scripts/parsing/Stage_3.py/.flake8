[flake8]
# Line length matches Black default
max-line-length = 88

# Ignore certain rules for flexibility:
# E203: whitespace before ':' (conflicts with Black)
# W503: line break before binary operator (deprecated)
# E501: line too long (handled by max-line-length with some flexibility)
extend-ignore = E203, W503

# Exclude common non-source directories
exclude = 
    .git,
    __pycache__,
    venv,
    .venv,
    env,
    build,
    dist,
    *.egg-info,
    .pytest_cache,
    .mypy_cache

# Per-file ignores for tests (allow longer lines, unused imports in fixtures)
per-file-ignores = 
    tests/*: E501, F401
    __init__.py: F401

# Statistics
statistics = True
count = True
